---
import Layout from '../layouts/Layout.astro';
import Intro from '../components/Intro.astro';
import Console from '../components/Console.astro';

// Projects shown as tiles. Flip `status` to 'live' once each subdomain
// is deployed. Swap `note` for your own (humorous) tagline anytime.
const projects = [
  {
    label: 'FX Orbit',
    href: 'https://fxorbit.surbitonix.com',
    note: 'Give the KUBE to the Masses',
    status: 'soon',
  },
  {
    label: 'Jyra',
    href: 'https://jyra.surbitonix.com',
    // Pun: most of continental Europe says "J-ai-ra"; it's actually "J-ee-ra".
    note: 'Since everyone calls it J<em>ai</em>ra, here you have it (your J<em>ai</em>ra)&hellip; but the real one is called J<em>ee</em>ra.',
    status: 'soon',
  },
];

const links = [
  {
    label: 'Email',
    href: 'mailto:hello@surbitonix.com',
    note: 'I answer every now and then. But i always answer....eventually...',
  },
  {
    label: 'GitHub',
    href: 'https://github.com/Surbitonix',
    note: 'Your life is more exciting than this... you deserve better',
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/manuel-m-672bb35/',
    note: 'Humble Bragging Time',
    wide: true,
  },
];
---

<Layout title="surbitonix" description="The personal portal of surbitonix.">
  <Intro />
  <main>
    <section class="hero">
      <span class="badge">welcome to the future</span>
      <h1>
        <span class="grad">surbitonix</span><span class="cursor" aria-hidden="true">_</span>
      </h1>
      <p class="tagline">
        Trading engineer. Building tools, experiments, and the occasional
        <s>well-structured</s> chaotic repository.
      </p>
    </section>

    <section class="workspace">
      <div class="panel panel-tiles">
      <span class="section-label">
        <span class="prompt-path">~/projects</span>
        <span class="prompt-sym">$</span>
        <span class="prompt-cmd">ls</span>
      </span>
      <div class="links">
        {
          projects.map((project) => (
            <a
              class="card"
              href={project.href}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="card-top">
                <span class="card-label">{project.label}</span>
                <span class={`pill ${project.status === 'live' ? 'pill-live' : ''}`}>
                  {project.status === 'live' ? 'live' : 'soon'}
                </span>
              </span>
              <span class="card-note" set:html={project.note} />
            </a>
          ))
        }
      </div>

      <span class="section-label">
        <span class="prompt-path">~/connect</span>
        <span class="prompt-sym">$</span>
        <span class="prompt-cmd">ping</span>
        <span class="section-sub">— you dont have to</span>
      </span>
      <div class="links">
        {
          links.map((link) => (
            <a
              class={`card ${link.wide ? 'card-wide' : ''}`}
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="card-label">{link.label}</span>
              <span class="card-note">{link.note}</span>
            </a>
          ))
        }
      </div>
      </div>

      <aside class="panel panel-console">
      <span class="section-label">
        <span class="prompt-path">~</span>
        <span class="prompt-sym">$</span>
        <span class="prompt-cmd">./shell</span>
        <span class="section-sub">— yes, it actually works</span>
      </span>
      <Console />
      </aside>
    </section>

    <footer>
      <span>© {new Date().getFullYear()} surbitonix</span>
      <span class="dot">·</span>
      <span>surbitonix.com</span>
    </footer>
  </main>
</Layout>

<style>
  main {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    position: relative;
    overflow-x: hidden;
  }

  main::before {
    content: '';
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 900px;
    max-width: 120vw;
    background: radial-gradient(
      circle,
      rgba(99, 102, 241, 0.18),
      rgba(34, 211, 238, 0.06) 45%,
      transparent 70%
    );
    pointer-events: none;
  }

  .hero {
    position: relative;
    text-align: center;
    max-width: 640px;
  }

  .badge {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: clamp(2.75rem, 8vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  .grad {
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .cursor {
    color: var(--accent-2);
    margin-left: 0.06em;
    font-weight: 700;
    animation: blink 1.1s steps(1, end) infinite;
  }

  @keyframes blink {
    0%,
    50% {
      opacity: 1;
    }
    50.01%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor {
      animation: none;
    }
  }

  .tagline {
    margin: 1.25rem auto 0;
    max-width: 32rem;
    color: var(--muted);
    font-size: 1.1rem;
  }

  .tagline s {
    opacity: 0.55;
    text-decoration-thickness: 1.5px;
  }

  .workspace {
    width: 100%;
    max-width: 640px;
    margin: 2.5rem auto 0;
    display: grid;
    gap: 1.75rem;
    text-align: left;
  }

  .panel {
    min-width: 0;
  }

  .panel > .section-label:first-child {
    margin-top: 0;
  }

    @media (min-width: 880px) {
    .workspace {
      max-width: 1040px;
      grid-template-columns: 1fr 1fr;
      align-items: start;
      gap: 2.25rem;
    }
  }

  .section-label {
    display: block;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    font-family: ui-monospace, 'JetBrains Mono', SFMono-Regular, Menlo,
      Consolas, monospace;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .prompt-path {
    color: var(--accent-2);
  }

  .prompt-sym {
    color: #4ade80;
    margin: 0 0.1rem 0 0.05rem;
  }

  .prompt-cmd {
    color: var(--fg);
    opacity: 0.85;
  }

  .section-sub {
    font-size: 0.72rem;
    font-style: italic;
    color: var(--muted);
    opacity: 0.75;
  }

  .links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (max-width: 30rem) {
    .links {
      grid-template-columns: 1fr;
    }
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--bg-soft);
    text-align: left;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .card-wide {
    grid-column: 1 / -1;
    justify-self: center;
    flex-direction: row;
    align-items: baseline;
    gap: 0.6rem;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-label {
    font-weight: 600;
  }

  .card-note {
    font-size: 0.9rem;
    color: var(--muted);
  }

  .pill {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.12rem 0.5rem;
    white-space: nowrap;
  }

  .pill-live {
    color: #4ade80;
    border-color: rgba(74, 222, 128, 0.4);
  }

  footer {
    margin-top: 3rem;
    display: flex;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .dot {
    opacity: 0.5;
  }
</style>
