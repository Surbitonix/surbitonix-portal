---
import Layout from '../layouts/Layout.astro';
import Intro from '../components/Intro.astro';
import Console from '../components/Console.astro';

// Portal release tag — bump when merging to main (next merge → v0.0.9).
const portalVersion = 'v0.0.9';

// CodeForge — umbrella learning portal. Each entry below is a *track* (a
// subset): LinuxMaster ships first; SQL, Python, Bash, … follow. To add a
// track, append to `tracks`. Give it an `href` + version `status` once its
// site is live; leave `href` off (status: 'soon') for a not-yet-built track.
const codeforge = {
  label: 'CodeForge',
    note: 'Interactive learning portal for trading engineers — build real muscle memory across Linux, Bash, Python &amp; more.',
  tracks: [
    {
      label: 'LinuxMaster',
      href: 'https://linuxmaster.surbitonix.com',
      status: 'v0.3.8',
    },
    { label: 'FIX Protocol', status: 'soon' },
    { label: 'Python', status: 'soon' },
    { label: 'SQL', status: 'soon' },
  ],
};

// Projects shown as tiles. Flip `status` to 'live' once each subdomain
// is deployed. Swap `note` for your own (humorous) tagline anytime.
const projects = [
  {
    label: 'KubeFX',
    href: 'https://kubefx.surbitonix.com',
    note: 'AI Powered FX Tech Demonstrator - Trade the News like a Pro',
    status: 'v2.7.0',
    pill: 'version',
  },
  {
    label: 'Jyra',
    href: 'https://jyra.surbitonix.com',
    // Pun: most of continental Europe says "J-ai-ra"; it's actually "J-ee-ra".
    note: 'Since everyone calls it J<em>ai</em>ra, here you have it (your J<em>ai</em>ra)&hellip; but the real one is called J<em>ee</em>ra.',
    status: 'v0.0.4',
    pill: 'version',
  },
];

const links = [
  {
    label: 'Email',
    href: 'mailto:hello@surbitonix.com',
    note: 'I answer every now and then. But i always answer....eventually...',
  },
  {
    label: 'GitHub',
    href: 'https://github.com/Surbitonix',
    note: 'Your life is more exciting than this... you deserve better',
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/manuel-m-672bb35/',
    note: 'Humble Bragging Time',
    wide: true,
  },
];
---

<Layout
  title="surbitonix"
  description="Trading engineer. Building tools, experiments, and KubeFX — an AI-powered FX tech demonstrator."
  ogTitle="KubeFX — AI-Powered FX Tech Demonstrator"
  ogDescription="Trade the News like a Pro. Real-time FX data visualization meets AI news sentiment analysis."
  ogUrl="https://surbitonix.com"
>
  <Intro />
  <main>
    <section class="hero">
      <span class="badge">welcome to the future</span>
      <h1>
        <span class="grad" id="brand" data-text="surbitonix">surbitonix</span
        ><span class="cursor" aria-hidden="true">_</span>
      </h1>
      <script is:inline>
        // Clear the brand text pre-paint so it can "type" in on reveal.
        // Reduced-motion users keep the full word (no typing).
        (function () {
          try {
            if (window.matchMedia('(prefers-reduced-motion: reduce)').matches)
              return;
            var b = document.getElementById('brand');
            if (b) b.textContent = '';
          } catch (e) {
            /* leave the word as-is */
          }
        })();
      </script>
      <p class="tagline">
        Trading engineer. Building tools, experiments, and the occasional
        <s>well-structured</s> chaotic repository.
      </p>
    </section>

    <section class="workspace">
      <div class="panel panel-codeforge">
      <span class="section-label">
        <span class="prompt-path">~/codeforge</span>
        <span class="prompt-sym">$</span>
        <span class="prompt-cmd">ls --tracks</span>
      </span>
      <div class="codeforge">
        <div class="cf-head">
          <span class="cf-prompt" aria-hidden="true">&gt;_</span>
          <span class="cf-brand">{codeforge.label}</span>
        </div>
        <p class="cf-tag" set:html={codeforge.note} />
        <div class="cf-tracks">
          {
            codeforge.tracks.map((track) =>
              track.href ? (
                <a
                  class="cf-track"
                  href={track.href}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span class="cf-track-label">{track.label}</span>
                  <span class="cf-track-ver">{track.status}</span>
                </a>
              ) : (
                <span class="cf-track cf-track-soon">
                  <span class="cf-track-label">{track.label}</span>
                  <span class="pill pill-soon">{track.status}</span>
                </span>
              )
            )
          }
        </div>
      </div>
      </div>

      <div class="panel panel-tiles">
      <span class="section-label">
        <span class="prompt-path">~/projects</span>
        <span class="prompt-sym">$</span>
        <span class="prompt-cmd">ls --projects</span>
      </span>
      <div class="links">
        {
          projects.map((project) => (
            <a
              class="card"
              href={project.href}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="card-top">
                <span class="card-label">{project.label}</span>
                {
                  project.pill !== 'version' && (
                    <span class={`pill pill-${project.pill ?? project.status}`}>
                      {project.status}
                    </span>
                  )
                }
              </span>
              <span class="card-note" set:html={project.note} />
              {
                project.pill === 'version' && (
                  <span class="card-version">{project.status}</span>
                )
              }
            </a>
          ))
        }
      </div>

      <span class="section-label">
        <span class="prompt-path">~/connect</span>
        <span class="prompt-sym">$</span>
        <span class="prompt-cmd">ping</span>
        <span class="section-sub">— if you must</span>
      </span>
      <div class="links">
        {
          links.map((link) => (
            <a
              class={`card ${link.wide ? 'card-wide' : ''}`}
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="card-label">{link.label}</span>
              <span class="card-note">{link.note}</span>
            </a>
          ))
        }
      </div>
      </div>

      <aside class="panel panel-console">
      <span class="section-label">
        <span class="prompt-path">~</span>
        <span class="prompt-sym">$</span>
        <span class="prompt-cmd">./shell</span>
        <span class="section-sub">— yes, it actually works</span>
      </span>
      <Console />
      </aside>
    </section>

    <footer>
      <div class="footer-line">
        <span>© {new Date().getFullYear()} surbitonix</span>
        <span class="dot">·</span>
        <span>surbitonix.com</span>
      </div>
      <p class="portal-version">{portalVersion}</p>
    </footer>
  </main>
</Layout>

<script>
  // Types out the "surbitonix" brand once the intro reveals the page,
  // leaving the blinking "_" cursor after it.
  function setupBrandTypewriter() {
    const html = document.documentElement;
    const brand = document.getElementById('brand');
    if (!brand) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const word = brand.dataset.text || 'surbitonix';
    let started = false;

    function type() {
      if (started) return;
      started = true;
      let i = 0;
      const step = () => {
        brand.textContent = word.slice(0, i);
        if (i < word.length) {
          i++;
          window.setTimeout(step, 150);
        }
      };
      step();
    }

    // If there's no intro to wait for (or it already finished), type now.
    const introEl = document.getElementById('intro');
    if (!introEl || html.classList.contains('intro-done')) {
      type();
      return;
    }

    // Otherwise type as the intro begins revealing the landing page.
    document.addEventListener('intro:reveal', () => window.setTimeout(type, 200), {
      once: true,
    });

    // Safety net well beyond the longest the intro can run.
    window.setTimeout(type, 30000);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupBrandTypewriter);
  } else {
    setupBrandTypewriter();
  }
</script>

<style>
  main {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    position: relative;
    overflow-x: hidden;
  }

  main::before {
    content: '';
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 900px;
    max-width: 120vw;
    background: radial-gradient(
      circle,
      rgba(99, 102, 241, 0.18),
      rgba(34, 211, 238, 0.06) 45%,
      transparent 70%
    );
    pointer-events: none;
  }

  .hero {
    position: relative;
    text-align: center;
    max-width: 640px;
  }

  .badge {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: clamp(2.75rem, 8vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  .grad {
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .cursor {
    color: var(--accent-2);
    margin-left: 0.06em;
    font-weight: 700;
    animation: blink 1.1s steps(1, end) infinite;
  }

  @keyframes blink {
    0%,
    50% {
      opacity: 1;
    }
    50.01%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor {
      animation: none;
    }
  }

  .portal-version {
    margin: 0;
    font-family: ui-monospace, 'JetBrains Mono', SFMono-Regular, Menlo,
      Consolas, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--muted);
    opacity: 0.7;
  }

  .tagline {
    margin: 1.25rem auto 0;
    max-width: 32rem;
    color: var(--muted);
    font-size: 1.1rem;
  }

  .tagline s {
    opacity: 0.55;
    text-decoration-thickness: 1.5px;
  }

  .workspace {
    width: 100%;
    max-width: 640px;
    margin: 2.5rem auto 0;
    display: grid;
    gap: 1.75rem;
    text-align: left;
    /* Mobile: a single stacked column (codeforge → projects → console).
       minmax(0, 1fr) lets the column shrink to the viewport so wide
       content (e.g. the console) wraps instead of overflowing. */
    grid-template-columns: minmax(0, 1fr);
    grid-template-areas:
      'cf'
      'proj'
      'console';
  }

  .panel {
    min-width: 0;
  }

  .panel > .section-label:first-child {
    margin-top: 0;
  }

  .panel-codeforge {
    grid-area: cf;
  }

  .panel-tiles {
    grid-area: proj;
  }

  .panel-console {
    grid-area: console;
  }

  /* Two columns once there's room: CodeForge stacks over Projects on the
     left, the console fills the right. */
  @media (min-width: 880px) and (max-width: 1099px) {
    .workspace {
      max-width: 1040px;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      grid-template-areas:
        'cf console'
        'proj console';
      align-items: start;
      gap: 2.25rem;
    }
  }

  /* Three columns on wider desktops: codeforge | projects | console. */
  @media (min-width: 1100px) {
    .workspace {
      max-width: 1240px;
      grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr) minmax(0, 1.05fr);
      grid-template-areas: 'cf proj console';
      align-items: start;
      gap: 2rem;
    }
  }

  .section-label {
    display: block;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    font-family: ui-monospace, 'JetBrains Mono', SFMono-Regular, Menlo,
      Consolas, monospace;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .prompt-path {
    color: var(--accent-2);
  }

  .prompt-sym {
    color: #4ade80;
    margin: 0 0.1rem 0 0.05rem;
  }

  .prompt-cmd {
    color: var(--fg);
    opacity: 0.85;
  }

  .section-sub {
    font-size: 0.72rem;
    font-style: italic;
    color: var(--muted);
    opacity: 0.75;
  }

  .links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (max-width: 30rem) {
    .links {
      grid-template-columns: 1fr;
    }
  }

  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.1rem 1.25rem 1.65rem;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--bg-soft);
    text-align: left;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .card-wide {
    grid-column: 1 / -1;
    justify-self: center;
    flex-direction: row;
    align-items: baseline;
    gap: 0.6rem;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-label {
    font-weight: 600;
  }

  .card-note {
    font-size: 0.9rem;
    color: var(--muted);
  }

  .card-version {
    position: absolute;
    right: 1rem;
    bottom: 0.55rem;
    font-family: ui-monospace, 'JetBrains Mono', SFMono-Regular, Menlo,
      Consolas, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    opacity: 0.55;
  }

  .pill {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.12rem 0.5rem;
    white-space: nowrap;
  }

  .pill-live {
    color: #4ade80;
    border-color: rgba(74, 222, 128, 0.4);
  }

  .pill-beta {
    color: #fbbf24;
    border-color: rgba(251, 191, 36, 0.4);
  }

  /* CodeForge — branded category card holding learning tracks (subsets). */
  .codeforge {
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--bg-soft);
    padding: 1.2rem 1.25rem 1.3rem;
  }

  .cf-head {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
  }

  .cf-prompt {
    font-family: ui-monospace, 'JetBrains Mono', SFMono-Regular, Menlo,
      Consolas, monospace;
    font-weight: 700;
    color: #4ade80;
  }

  .cf-brand {
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .cf-tag {
    margin: 0.5rem 0 1rem;
    font-size: 0.88rem;
    color: var(--muted);
  }

  .cf-tracks {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.6rem;
  }

  .cf-track {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg);
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  a.cf-track:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .cf-track-soon {
    opacity: 0.55;
  }

  .cf-track-label {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .cf-track-ver {
    font-family: ui-monospace, 'JetBrains Mono', SFMono-Regular, Menlo,
      Consolas, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  footer {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .footer-line {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .dot {
    opacity: 0.5;
  }
</style>
