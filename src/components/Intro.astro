---
// Two-stage cinematic intro:
//  Stage B: branded cityscape billboard with a slow Ken Burns zoom
//  Stage A: terminal "boot" typing sequence, ending on a humorous
//           "Press Enter to continue" prompt that auto-advances if
//           the visitor doesn't press anything.
// then fades into the page. Skipped entirely for users who prefer
// reduced motion.
---

<!-- `is:inline` keeps this script inline & unbundled so it runs synchronously
     during parse, BEFORE the overlay paints. That lets reduced-motion users
     skip the intro with no flash of the animation. -->
<script is:inline>
  (function () {
    try {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('intro-done');
      }
    } catch (e) {
      /* matchMedia unavailable: just play the intro */
    }
  })();
</script>

<div id="intro" class="intro" aria-hidden="true">
  <!-- Stage B: cinematic image -->
  <div class="stage stage-image is-active" data-stage="image">
    <div class="kenburns"></div>
    <div class="vignette"></div>
  </div>

  <!-- Stage A: terminal boot -->
  <div class="stage stage-terminal" data-stage="terminal">
    <pre class="term"><code id="term-out"></code><span class="term-caret">_</span></pre>
  </div>

  <button type="button" class="skip" data-skip>Skip &rsaquo;</button>
</div>

<!-- Pick the random backdrop SYNCHRONOUSLY here, before first paint, so the
     page never shows the default image and then swaps (which caused a visible
     flicker). This runs right after #intro is parsed, so .kenburns exists. -->
<script is:inline>
  (function () {
    try {
      var imgs = [
        '/surbitonix-building.png',
        '/intro/surbitonix-f1.png',
        '/intro/surbitonix-plane.png',
        '/intro/surbitonix-stadium.png',
        '/intro/surbitonix-highway.png',
        '/intro/surbitonix-times-square.png',
        '/intro/surbitonix-metro.png',
        '/intro/surbitonix-desert.png',
        '/intro/surbitonix-rooftop.png',
        '/intro/surbitonix-racetrack.png',
      ];
      var el = document.querySelector('.kenburns');
      if (el) {
        var pick = imgs[Math.floor(Math.random() * imgs.length)];
        el.style.backgroundImage = "url('" + pick + "')";
      }
    } catch (e) {
      /* keep the CSS fallback image */
    }
  })();
</script>

<style>
  /* Hide intro entirely once it's done (set on <html>). */
  :global(html.intro-done) #intro {
    display: none;
  }

  /* While the intro plays, lock the page behind it. */
  :global(html:not(.intro-done)) {
    overflow: hidden;
  }

  .intro {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #000;
    overflow: hidden;
    opacity: 1;
    transition: opacity 0.8s ease;
  }

  .intro.fade-out {
    opacity: 0;
    pointer-events: none;
  }

  .stage {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.7s ease;
  }

  .stage.is-active {
    opacity: 1;
  }

  /* --- Stage B: cityscape with Ken Burns zoom ---
     The image is chosen at random per visit by the script below; this URL is
     just a fallback if the script doesn't run. */
  .kenburns {
    position: absolute;
    inset: 0;
    background-image: url('/surbitonix-building.png');
    background-size: cover;
    background-position: center;
    transform: scale(1.05);
    animation: kenburns 6s ease-out forwards;
  }

  @keyframes kenburns {
    from {
      transform: scale(1.05);
    }
    to {
      transform: scale(1.18) translateY(-1.5%);
    }
  }

  .vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 50% 45%,
      transparent 35%,
      rgba(0, 0, 0, 0.55) 100%
    );
  }

  /* --- Stage A: terminal --- */
  .stage-terminal {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0b0c10;
  }

  .term {
    font-family: 'SFMono-Regular', ui-monospace, 'JetBrains Mono', Menlo,
      Consolas, monospace;
    font-size: clamp(0.85rem, 2.4vw, 1.15rem);
    line-height: 1.7;
    color: #e7e9ee;
    margin: 0;
    padding: 1.5rem;
    max-width: min(92vw, 640px);
    white-space: pre-wrap;
    word-break: break-word;
  }

  .term :global(.prompt) {
    color: #22d3ee;
  }
  .term :global(.ok) {
    color: #4ade80;
  }
  .term :global(.dim) {
    color: #9aa1ad;
  }
  .term :global(.hint) {
    color: #fbbf24;
    animation: hintPulse 1.6s ease-in-out infinite;
  }

  @keyframes hintPulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.55;
    }
  }

  .term-caret {
    display: inline-block;
    color: #22d3ee;
    font-weight: 700;
    animation: caret 1.1s steps(1, end) infinite;
  }

  @keyframes caret {
    0%,
    50% {
      opacity: 1;
    }
    50.01%,
    100% {
      opacity: 0;
    }
  }

  .skip {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 2;
    font: inherit;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: #e7e9ee;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    padding: 0.5rem 1.1rem;
    cursor: pointer;
    backdrop-filter: blur(6px);
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .skip:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: #6366f1;
  }
</style>

<script>
  type Line = { text: string; cls?: string; pause?: number };

  function runIntro() {
    const html = document.documentElement;
    if (html.classList.contains('intro-done')) return;

    const intro = document.getElementById('intro');
    if (!intro) return;

    const imageStage = intro.querySelector<HTMLElement>('[data-stage="image"]');
    const termStage = intro.querySelector<HTMLElement>('[data-stage="terminal"]');
    const out = document.getElementById('term-out');
    const skipBtn = intro.querySelector<HTMLElement>('[data-skip]');

    // `finished` guards against the intro ending twice (e.g. auto-advance
    // racing a manual skip). Every timeout id is tracked in `timers` so that
    // finish() can cancel any pending waits the moment the user skips.
    let finished = false;
    const timers: number[] = [];
    const wait = (ms: number) =>
      new Promise<void>((res) => timers.push(window.setTimeout(res, ms)));

    function finish() {
      if (finished) return;
      finished = true;
      timers.forEach((t) => clearTimeout(t));
      intro!.classList.add('fade-out');
      // Tell the landing page the reveal has started, so it can
      // type out the "surbitonix" brand as the overlay fades.
      document.dispatchEvent(new CustomEvent('intro:reveal'));
      window.setTimeout(() => {
        html.classList.add('intro-done');
      }, 800);
    }

    skipBtn?.addEventListener('click', finish);
    const onKey = (e: KeyboardEvent) => {
      if (e.key === 'Escape' || e.key === 'Enter') finish();
    };
    window.addEventListener('keydown', onKey);

    const lines: Line[] = [
      { text: '$ ssh surbitonix.com', cls: 'prompt', pause: 650 },
      { text: '[ ok ] establishing secure channel', cls: 'ok', pause: 550 },
      { text: '[ ok ] loading the future', cls: 'ok', pause: 700 },
    ];

    // The humorous, slightly reassuring prompt that ends the sequence.
    const hint: Line = {
      text: 'Press Enter to continue....',
      cls: 'hint',
      pause: 0,
    };

    // How long to wait at the prompt before auto-advancing to the page.
    const AUTO_ADVANCE_MS = 6000;

    async function typeLine(line: Line) {
      const span = document.createElement('span');
      if (line.cls) span.className = line.cls;
      out!.appendChild(span);
      for (const ch of line.text) {
        span.textContent += ch;
        await wait(55);
      }
      out!.appendChild(document.createTextNode('\n'));
      await wait(line.pause ?? 200);
    }

    async function sequence() {
      // After every `await`, bail if the user skipped while we were waiting —
      // otherwise the sequence would keep mutating the DOM behind the fade.
      // Stage B: hold the cinematic shot for a slow, deliberate beat
      await wait(3500);
      if (finished) return;

      // Cross-fade to the terminal
      imageStage?.classList.remove('is-active');
      termStage?.classList.add('is-active');
      await wait(700);
      if (finished) return;

      // Stage A: type the boot sequence
      for (const line of lines) {
        if (finished) return;
        await typeLine(line);
      }
      if (finished) return;

      // The "Press Enter" prompt: Enter (or Esc / Skip) finishes
      // immediately; otherwise it auto-advances on its own.
      await typeLine(hint);
      if (finished) return;

      await wait(AUTO_ADVANCE_MS);
      finish();
    }

    sequence();
  }

  // Module scripts are deferred, so the DOM is usually ready by the time this
  // runs — but guard for the rare "still loading" case just in case.
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', runIntro);
  } else {
    runIntro();
  }
</script>
